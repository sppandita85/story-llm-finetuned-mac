# Ollama Modelfile for the from-scratch story LLM.
# Build:  cd phase10_ollama_export && ollama create story-llm -f Modelfile
# Run:    ollama run story-llm "What is the moral of 'The Boy Who Cried Wolf'?"

FROM ./story-llm.gguf

# Description that travels WITH the model (view via `ollama show --system`).
# NOTE: the TEMPLATE below intentionally does NOT reference {{ .System }}, so this
# text is metadata only and is never injected into generation — the tiny model
# was trained without system prompts, so injecting one would worsen output.
SYSTEM """story-llm: a 0.94M-parameter GPT built from scratch and trained on 50 children's moral stories. An educational reproduction of the full LLM pipeline (custom BPE -> pretraining -> SFT -> Ollama). Learning artifact only; output is garbled at this scale. Source: https://github.com/sppandita85/story-llm-finetuned-mac"""

# Match the instruction template used during fine-tuning (common/chat_format.py):
#   <|user|>\n{question}\n<|assistant|>\n{answer}<|endoftext|>
TEMPLATE """<|user|>
{{ .Prompt }}
<|assistant|>
"""

# Stop generating when the model emits a turn/document boundary.
PARAMETER stop "<|endoftext|>"
PARAMETER stop "<|user|>"

# Sampling (same spirit as phase9_chat).
PARAMETER temperature 0.7
PARAMETER top_k 40
PARAMETER num_ctx 128
